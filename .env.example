# ================================================
# FutureLeap AI — Environment Variables
# ================================================
# 1. Copy:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to git
# ================================================

# ── Supabase ──────────────────────────────────
# Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── OpenAI (LOCAL DEV ONLY) ───────────────────
# Used by src/lib/openai.js when running `npm run dev`
# In production, only OPENAI_API_KEY (no VITE_ prefix) is used
# by the Vercel serverless function in /api/generate.js
VITE_OPENAI_API_KEY=sk-your-openai-api-key

# ── OpenAI (VERCEL PRODUCTION - server-side) ──
# Add this in Vercel Dashboard → Project → Settings → Environment Variables
# Do NOT prefix with VITE_ — keeps the key off the browser bundle
OPENAI_API_KEY=sk-your-openai-api-key

# ── App URL ───────────────────────────────────
VITE_APP_URL=http://localhost:5173
